#include <stdio.h>
#include <ctype.h>
#include <string.h>

int isOperator(char ch)
{
    return (ch == '+' || ch == '-' || ch == '*' ||
            ch == '/' || ch == '%' || ch == '=' ||
            ch == '<' || ch == '>' || ch == '!' ||
            ch == '&' || ch == '|');
}

int main()
{
    FILE *fp;
    char ch;

    fp = fopen("input.c", "r");

    if (fp == NULL)
    {
        printf("Cannot open file.\n");
        return 1;
    }

    while ((ch = fgetc(fp)) != EOF)
    {
        /* Ignore spaces, tabs, newlines */
        if (isspace(ch))
            continue;

        /* Ignore single-line comments */
        if (ch == '/')
        {
            char next = fgetc(fp);

            if (next == '/')
            {
                while ((ch = fgetc(fp)) != '\n' && ch != EOF);
                continue;
            }

            /* Ignore multi-line comments */
            else if (next == '*')
            {
                char prev = 0;
                while ((ch = fgetc(fp)) != EOF)
                {
                    if (prev == '*' && ch == '/')
                        break;
                    prev = ch;
                }
                continue;
            }
            else
            {
                ungetc(next, fp);
            }
        }

        /* Identifier */
        if (isalpha(ch) || ch == '_')
        {
            char buffer[50];
            int i = 0;

            do
            {
                if (i < 49)
                    buffer[i++] = ch;
                ch = fgetc(fp);
            } while (isalnum(ch) || ch == '_');

            buffer[i] = '\0';

            printf("Identifier : %s\n", buffer);

            if (ch != EOF)
                ungetc(ch, fp);
        }

        /* Numeric Constant */
        else if (isdigit(ch))
        {
            char buffer[50];
            int i = 0;

            do
            {
                if (i < 49)
                    buffer[i++] = ch;
                ch = fgetc(fp);
            } while (isdigit(ch) || ch == '.');

            buffer[i] = '\0';

            printf("Constant   : %s\n", buffer);

            if (ch != EOF)
                ungetc(ch, fp);
        }

        /* Operator */
        else if (isOperator(ch))
        {
            printf("Operator   : %c\n", ch);
        }
    }

    fclose(fp);
    return 0;
}
